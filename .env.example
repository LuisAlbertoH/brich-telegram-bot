# Required to start the bot
TELEGRAM_BOT_TOKEN=123456789:replace_with_real_bot_token

# Will be set automatically by /setup (single authorized chat)
AUTHORIZED_CHAT_ID=

# Setup gate password (required to enter /setup)
SETUP_PASSWORD=change_me_now

# Raspberry SSH target
RPI_HOST=192.168.1.50
RPI_PORT=22
RPI_USER=pi
# SSH auth mode:
# - password: uses RPI_PASSWORD
# - key: uses RPI_SSH_KEY_PATH (local path to private key file)
RPI_AUTH_MODE=password
# Used only when RPI_AUTH_MODE=password
RPI_PASSWORD=replace_with_password_if_auth_mode_password
# Used only when RPI_AUTH_MODE=key.
# Must point to the local private key that matches Raspberry authorized_keys.
# Examples:
# - macOS: /Users/your-user/.ssh/id_ed25519
# - Windows: C:/Users/your-user/.ssh/id_ed25519
RPI_SSH_KEY_PATH=~/.ssh/id_ed25519
RPI_PROJECT_PATH=/home/pi/brich

# Operational settings
SSH_TIMEOUT_SEC=10
# Local webcam capture settings (used by menu section "Camara")
# 0 is usually the default webcam
CAMERA_DEVICE_INDEX=0
# Number of warmup frames before taking photo
CAMERA_WARMUP_FRAMES=8
# Max seconds to wait for a valid frame
CAMERA_TIMEOUT_SEC=6

# Local automation recipes for macro-like workflows (JSON file)
LOCAL_RECIPES_PATH=automation_recipes.json
LOG_LEVEL=INFO
